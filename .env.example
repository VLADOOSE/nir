# Скопируй в .env на сервере (/srv/ais/.env) и заполни. В git .env НЕ коммитить!
# ---------------------------------------------------------------------------

# --- БД (внутренний Postgres АИС) ---
POSTGRES_USER=nir
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# --- Почта: отправка КП (боевой SMTP mail.ru, ящик zakup@westmed.kz) ---
MAIL_HOST=smtp.mail.ru
MAIL_PORT=465
MAIL_USERNAME=zakup@westmed.kz
MAIL_PASSWORD=CHANGE_ME_mailru_app_password   # пароль ПРИЛОЖЕНИЯ mail.ru, не основной
MAIL_SMTP_AUTH=true
MAIL_SMTP_SSL=true
MAIL_SMTP_STARTTLS=false
MAIL_KP_REPLY_TO=zakup@westmed.kz

# --- Почта: приём ответов/заявок (IMAP). Включать, когда готовы ловить вживую ---
MAIL_IMAP_ENABLED=false
MAIL_IMAP_HOST=imap.mail.ru
MAIL_IMAP_PORT=993
MAIL_IMAP_PROTOCOL=imaps
MAIL_IMAP_USERNAME=zakup@westmed.kz
MAIL_IMAP_PASSWORD=CHANGE_ME_mailru_app_password
MAIL_IMAP_MARKET=KZ
MAIL_IMAP_SINCE_MINUTES=60

# --- Госзакуп РК (импорт KZ-тендеров + разбор ТЗ). Токен протухает — перевыпускать ---
GOSZAKUP_TOKEN=CHANGE_ME_goszakup_token
GOSZAKUP_IMPORT_ENABLED=false     # авто-поллинг раз в 6ч; кнопка «Обновить» работает и без этого
SKPHARMACY_IMPORT_ENABLED=false
